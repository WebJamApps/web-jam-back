{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowJs": false,
    "checkJs": false,
    "outDir": "./build",
    "rootDir": ".",
    "resolveJsonModule": true,
    "types": ["node", "vitest/globals"],
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": false,
    "paths": {
      "#src/*": ["./src/*"],
      "#lib/*": ["./src/lib/*"]
    },
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": ["dist", "node_modules", "JaMmusic", "build", "coverage"],
  "include": ["./src/**/*", "./test/**/*"]
}
